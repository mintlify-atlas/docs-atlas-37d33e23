  "keyFeatures": [
    "Node-based visual workflow interface for stable diffusion",
    "Support for 30+ image, video, audio, and 3D AI models",
    "REST and WebSocket API for programmatic control",
    "Custom node system with extension support",
    "Advanced memory management and GPU optimization",
    "Model quantization for efficient inference",
    "Multi-platform support (Windows, Linux, macOS)",
    "Asynchronous queue system with workflow caching"
  ],
  "publicApiSurface": [
    "/prompt - Queue workflows for execution",
    "/history - Get execution history",
    "/queue - Manage execution queue",
    "/view - Retrieve generated images",
    "WebSocket - Real-time execution updates",
    "CLIPTextEncode - Text prompt encoding",
    "KSampler - Sampling node",
    "CheckpointLoaderSimple - Model loading",
    "VAEDecode - VAE decoding",
    "SaveImage - Image saving",
    "Custom Node API - Extension development"
